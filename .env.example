# Local open-source mode is the default.
# Run `python app.py` without these values for a private localhost app.

# Remote mode protects the app, conversion endpoints, and document history.
APP_MODE=remote
REMOTE_AUTH_PASSWORD=change-me
SECRET_KEY=replace-with-a-long-random-string

# Optional persistent remote history (Render, AWS Lambda).
MONGODB_URI=

# Optional AI features.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
DAILY_QUOTA=50
